      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-weight: 700;
      color: rgba(240, 244, 248, 0.93);
      margin-bottom: 1rem;
    }
    .legal-content p {
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.8;
      margin-bottom: 0.75rem;
    }
    .legal-content strong {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 600;
    }
    .legal-content ul {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin: 0.75rem 0;
    }
    .legal-content li {
      color: rgba(255, 255, 255, 0.7);
      padding-left: 1.25rem;
      position: relative;
      line-height: 1.7;
    }
    .legal-content li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.65em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(8, 145, 178, 0.6);
    }
